# Image versions
POLARIS_VERSION=latest
MC_VERSION=RELEASE.2025-08-13T08-35-41Z
DUCKDB_VERSION=1.5.3

# Polaris OAuth (root bootstrap — used only by polaris-setup)
POLARIS_REALM=POLARIS
POLARIS_ROOT_CLIENT_ID=root
POLARIS_ROOT_CLIENT_SECRET=s3cr3t

# Iceberg REST catalog name created in Polaris (Spark: spark.sql.catalog.polaris.warehouse)
POLARIS_CATALOG_NAME=lake

# Host ports (change if they collide)
POLARIS_API_PORT=8181
POLARIS_ADMIN_PORT=8182

# Module 01 MinIO warehouse (must match 01_Kafka_Iceberg)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
WAREHOUSE_BUCKET=warehouse
ICEBERG_NAMESPACE=lakehouse
